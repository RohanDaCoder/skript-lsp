{
    "name": "intelliskript",
    "displayName": "IntelliSkript",
    "version": "1.7.30",
    "private": true,
    "description": "Language server and VS Code extension for Skript (Minecraft scripting language)",
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "language-server",
        "lsp",
        "minecraft",
        "skript"
    ],
    "homepage": "https://github.com/intelliskript/intelliskript#readme",
    "bugs": {
        "url": "https://github.com/intelliskript/intelliskript/issues"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/intelliskript/intelliskript"
    },
    "publisher": "IntelliSkript",
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "vscode:prepublish": "bun run build",
        "build": "bun run build:client && bun run build:server",
        "build:client": "bun build client/src/nodeClientMain.ts --target=node --format=cjs --outfile=client/dist/nodeClientMain.js --external=vscode --external=@vscode/extension-telemetry && bun build client/src/browserClientMain.ts --target=browser --format=iife --outfile=client/dist/browserClientMain.js --external=vscode --external=@vscode/extension-telemetry",
        "build:server": "bun build server/src/nodeServerMain.ts --target=node --format=cjs --outfile=server/dist/nodeServerMain.js --external=vscode && bun build server/src/browserServerMain.ts --target=browser --format=iife --outfile=server/dist/browserServerMain.js --external=vscode",
        "build:all": "bun run --parallel build:client build:server",
        "typecheck": "tsc --noEmit",
        "typecheck:client": "tsc --noEmit -p client/tsconfig.json",
        "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
        "watch": "bun run build --watch",
        "package": "bun run build && vsce package",
        "lint": "bun x oxlint",
        "lint:fix": "bun x oxlint --fix",
        "fmt": "bun x oxfmt",
        "fmt:check": "bun x oxfmt --check",
        "chrome": "bun run build && vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ./test-data",
        "test": "vitest",
        "test:run": "vitest run",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@vscode/test-web": "^0.0.68",
        "oxfmt": "^0.45.0",
        "oxlint": "^1.60.0",
        "typescript": "^5.8.2",
        "vitest": "^4.1.4"
    },
    "contributes": {
        "languages": [
            {
                "id": "skript",
                "extensions": [
                    ".sk"
                ],
                "aliases": [
                    "Skript",
                    "sk",
                    "Sk-VSC",
                    "skriptlang"
                ],
                "filenames": [],
                "firstLine": "^#\\s*Skript",
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./graphics/skript icon.png",
                    "dark": "./graphics/skript icon.png"
                }
            }
        ],
        "configuration": [
            {
                "type": "object",
                "title": "IntelliSkript",
                "id": "IntelliSkript",
                "properties": {
                    "IntelliSkript.ErrorExempts": {
                        "scope": "resource",
                        "type": "string",
                        "default": "",
                        "description": "A RegExp which allows you to filter out annoying errors"
                    },
                    "IntelliSkript.UseColorTheme": {
                        "scope": "resource",
                        "type": "boolean",
                        "default": true,
                        "description": "Disable this and reload VS code if you have a skript color theme plugin installed"
                    }
                }
            }
        ],
        "semanticTokenTypes": [
            {
                "id": "pattern",
                "superType": "regexp",
                "description": "a skript pattern, like set %objects% to %objects%"
            },
            {
                "id": "permission",
                "superType": "string",
                "description": "a permission which a player needs to have to execute a command"
            },
            {
                "id": "expression",
                "superType": "property",
                "description": "an expression"
            },
            {
                "id": "condition",
                "superType": "property",
                "description": "a condition (if)"
            },
            {
                "id": "effect",
                "superType": "method",
                "description": "an effect"
            }
        ],
        "semanticTokenModifiers": [
            {
                "id": "bukkit_0",
                "description": "Bukkit color code &0"
            },
            {
                "id": "bukkit_1",
                "description": "Bukkit color code &1"
            },
            {
                "id": "bukkit_2",
                "description": "Bukkit color code &2"
            },
            {
                "id": "bukkit_3",
                "description": "Bukkit color code &3"
            },
            {
                "id": "bukkit_4",
                "description": "Bukkit color code &4"
            },
            {
                "id": "bukkit_5",
                "description": "Bukkit color code &5"
            },
            {
                "id": "bukkit_6",
                "description": "Bukkit color code &6"
            },
            {
                "id": "bukkit_7",
                "description": "Bukkit color code &7"
            },
            {
                "id": "bukkit_8",
                "description": "Bukkit color code &8"
            },
            {
                "id": "bukkit_9",
                "description": "Bukkit color code &9"
            },
            {
                "id": "bukkit_a",
                "description": "Bukkit color code &a"
            },
            {
                "id": "bukkit_b",
                "description": "Bukkit color code &b"
            },
            {
                "id": "bukkit_c",
                "description": "Bukkit color code &c"
            },
            {
                "id": "bukkit_d",
                "description": "Bukkit color code &d"
            },
            {
                "id": "bukkit_e",
                "description": "Bukkit color code &e"
            },
            {
                "id": "bukkit_f",
                "description": "Bukkit color code &f"
            },
            {
                "id": "bukkit_bold",
                "description": "Bukkit bold &b"
            },
            {
                "id": "bukkit_m",
                "description": "Bukkit strikethrough &m"
            },
            {
                "id": "bukkit_n",
                "description": "Bukkit underline &n"
            },
            {
                "id": "bukkit_o",
                "description": "Bukkit italic &o"
            }
        ],
        "themes": [
            {
                "label": "IntelliSkript->Colorful",
                "uiTheme": "vs-dark",
                "path": "./themes/IntelliSkript-Colorful.json"
            },
            {
                "label": "IntelliSkript->Dark Modern",
                "uiTheme": "vs-dark",
                "path": "./themes/IntelliSkript-Dark-Modern.json"
            },
            {
                "label": "IntelliSkrip->Light Modern",
                "uiTheme": "vs",
                "path": "./themes/IntelliSkript-Light-Modern.json"
            }
        ]
    },
    "activationEvents": [
        "onLanguage:Sk-VSC",
        "onLanguage:sk",
        "onLanguage:skriptlang"
    ],
    "extensionKind": [
        "ui",
        "workspace"
    ],
    "icon": "./graphics/icon_128x128.png",
    "engines": {
        "vscode": "^1.85.0"
    }
}
